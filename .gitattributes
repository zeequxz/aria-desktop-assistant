# Normalize line endings: store text as LF in the repo, check out native on
# each platform. Silences the "LF will be replaced by CRLF" warnings on Windows.
* text=auto

# Scripts that must keep a specific ending regardless of platform.
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.sh    text eol=lf

# Treat the build icon and other binaries as binary if added later.
*.ico   binary
*.png   binary
*.zip   binary
