# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# ── PyInstaller build artifacts ──────────────────────────────────────────────
# Generated by build_exe.bat / aria.spec. Release builds are published as
# GitHub Release assets instead of being committed.
build/
dist/
dist_build/
release/
*.manifest
*.zip

# ── App-local runtime data ───────────────────────────────────────────────────
# Real data lives in %APPDATA%\ARIA; ignore any stray copies in the working tree.
history/
memory/
logs/
tasks/
task_logs/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
Thumbs.db
desktop.ini
.DS_Store
